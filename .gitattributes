# Pre-computed volume/orbital assets are large binaries — track with Git LFS so
# clones stay light. Run `git lfs install` once before committing data/.
data/**/*.bin filter=lfs diff=lfs merge=lfs -text
data/**/*.glb filter=lfs diff=lfs merge=lfs -text
data/**/*.npy filter=lfs diff=lfs merge=lfs -text
